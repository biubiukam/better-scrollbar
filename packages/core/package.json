{
	"name": "@better-scrollbar/core",
	"version": "1.0.0",
	"description": "Framework-neutral virtual scrolling algorithms and utilities for better-scrollbar.",
	"license": "MIT",
	"author": "biubiukam",
	"type": "module",
	"homepage": "https://biubiukam.github.io/better-scrollbar/",
	"repository": {
		"type": "git",
		"url": "https://github.com/biubiukam/better-scrollbar",
		"directory": "packages/core"
	},
	"bugs": {
		"url": "https://github.com/biubiukam/better-scrollbar/issues"
	},
	"keywords": [
		"virtual-scroll",
		"virtualization",
		"scrollbar",
		"fenwick-tree",
		"virtual-list",
		"algorithms",
		"high-performance"
	],
	"engines": {
		"node": ">=18"
	},
	"main": "dist/better-scrollbar-core.cjs",
	"module": "dist/better-scrollbar-core.es.mjs",
	"unpkg": "dist/BetterScrollbarCore.min.js",
	"typings": "dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/better-scrollbar-core.es.mjs",
			"require": "./dist/better-scrollbar-core.cjs",
			"default": "./dist/better-scrollbar-core.es.mjs"
		},
		"./styles/ScrollBar.less": "./src/styles/ScrollBar.less"
	},
	"sideEffects": [
		"**/*.css",
		"**/*.less"
	],
	"files": [
		"dist",
		"src/styles"
	],
	"scripts": {
		"build": "vite build --config vite.config.mts && tsc -p tsconfig.json --emitDeclarationOnly",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run ../../test/corePackage.test.ts ../../test/virtualRange.test.ts",
		"clean": "rimraf dist"
	},
	"devDependencies": {
		"@types/node": "^20.10.3",
		"less": "^4.2.0",
		"typescript": "^5.3.2",
		"vite": "^5.0.8",
		"vitest": "^1.0.4"
	}
}
