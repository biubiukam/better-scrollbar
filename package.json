{
	"name": "@biubiukam/better-scrollbar",
	"version": "1.1.5",
	"description": "Highly customizable, high-performance React virtual scrollbar component for rendering massive data sets with custom scrollbars.",
	"packageManager": "pnpm@10.11.0",
	"keywords": [
		"react",
		"virtual-scroll",
		"virtual-list",
		"virtualization",
		"scrollbar",
		"custom-scrollbar",
		"infinite-scroll",
		"large-list",
		"dynamic-height",
		"scroll-anchoring",
		"high-performance",
		"react-component"
	],
	"homepage": "https://biubiukam.github.io/better-scrollbar/",
	"repository": {
		"type": "git",
		"url": "https://github.com/biubiukam/better-scrollbar"
	},
	"bugs": {
		"url": "https://github.com/biubiukam/better-scrollbar/issues"
	},
	"license": "MIT",
	"author": "biubiukam",
	"engines": {
		"node": ">=18"
	},
	"main": "dist/better-scrollbar.cjs",
	"module": "dist/better-scrollbar.es.mjs",
	"unpkg": "dist/ScrollBar.min.js",
	"typings": "dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/better-scrollbar.es.mjs",
			"require": "./dist/better-scrollbar.cjs",
			"default": "./dist/better-scrollbar.es.mjs"
		},
		"./dist/ScrollBar.min.css": "./dist/ScrollBar.min.css",
		"./dist/ScrollBar.min.js": "./dist/ScrollBar.min.js",
		"./dist/better-scrollbar.es.mjs": "./dist/better-scrollbar.es.mjs",
		"./dist/better-scrollbar.cjs": "./dist/better-scrollbar.cjs"
	},
	"sideEffects": [
		"**/*.css",
		"**/*.less"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build --config vite.config.lib.mts && tsc -p tsconfig.build.json",
		"site:build": "tsc -p tsconfig.site.json && vite build --config vite.config.site.mts",
		"site:dev": "vite --config vite.config.site.mts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --coverage",
		"test:dev": "vitest",
		"test:update": "vitest run --reporter=verbose --update-snapshots",
		"coverage": "cat ./coverage/lcov.info | coveralls",
		"prepack": "pnpm run build"
	},
	"devDependencies": {
		"@babel/preset-env": "^7.23.5",
		"@babel/preset-react": "^7.23.3",
		"@babel/preset-typescript": "^7.23.3",
		"@testing-library/react": "^14.0.0",
		"@types/dom-css": "^2.1.1",
		"@types/node": "^20.10.3",
		"@types/react": "^18.2.43",
		"@types/react-dom": "^18.2.17",
		"@types/sortablejs": "^1.15.7",
		"@vitejs/plugin-react": "^4.2.0",
		"@vitest/coverage-v8": "^1.0.4",
		"autoprefixer": "^10.5.0",
		"babel-plugin-jsx-remove-data-test-id": "^3.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.0",
		"coveralls": "^3.1.1",
		"dom-css": "^2.1.0",
		"eslint": "^8.17.0",
		"eslint-config-airbnb": "^19.0.4",
		"eslint-config-airbnb-typescript": "^17.0.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-import-resolver-typescript": "^2.7.1",
		"eslint-plugin-import": "^2.26.0",
		"eslint-plugin-jsx-a11y": "^6.5.1",
		"eslint-plugin-node": "^11.1.0",
		"eslint-plugin-prettier": "^4.0.0",
		"eslint-plugin-react": "^7.30.0",
		"eslint-plugin-react-hooks": "^4.5.0",
		"jsdom": "^20.0.0",
		"less": "^4.2.0",
		"lucide-react": "^1.20.0",
		"postcss": "^8.5.15",
		"prettier": "^3.1.0",
		"radix-ui": "^1.6.0",
		"react-sortablejs": "^6.1.4",
		"resize-observer-polyfill": "^1.5.1",
		"sortablejs": "^1.15.2",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^3.4.19",
		"tailwindcss-animate": "^1.0.7",
		"ts-node": "^10.9.1",
		"typescript": "^5.3.2",
		"use-immer": "^0.9.0",
		"vite": "^5.0.8",
		"vitest": "^1.0.4"
	},
	"peerDependencies": {
		"react": ">=16.9.0",
		"react-dom": ">=16.9.0"
	}
}
