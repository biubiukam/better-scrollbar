{
	"name": "better-scrollbar",
	"version": "2.0.2",
	"description": "Highly customizable, high-performance virtual scrollbar component. This package re-exports @better-scrollbar/react for backward compatibility.",
	"packageManager": "pnpm@10.11.0",
	"type": "module",
	"keywords": [
		"react",
		"vue",
		"virtual-scroll",
		"virtual-list",
		"virtualization",
		"scrollbar",
		"custom-scrollbar",
		"infinite-scroll",
		"large-list",
		"dynamic-height",
		"scroll-anchoring",
		"high-performance",
		"monorepo"
	],
	"homepage": "https://biubiukam.github.io/better-scrollbar/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/biubiukam/better-scrollbar.git"
	},
	"bugs": {
		"url": "https://github.com/biubiukam/better-scrollbar/issues"
	},
	"license": "MIT",
	"author": "biubiukam",
	"engines": {
		"node": ">=18"
	},
	"main": "dist/better-scrollbar.cjs",
	"module": "dist/better-scrollbar.es.mjs",
	"unpkg": "dist/ScrollBar.min.js",
	"types": "dist/types/library-entry.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/better-scrollbar.es.mjs",
			"require": "./dist/better-scrollbar.cjs",
			"default": "./dist/better-scrollbar.es.mjs"
		},
		"./styles": "./dist/ScrollBar.min.css"
	},
	"sideEffects": [
		"**/*.css",
		"**/*.less"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"build": "turbo run build",
		"build:compat": "vite build --config vite.config.lib.mts && tsc -p tsconfig.build.json",
		"dev": "turbo run dev",
		"site:build": "pnpm --filter @better-scrollbar/site build",
		"site:dev": "pnpm --filter @better-scrollbar/site dev",
		"lint": "eslint .",
		"typecheck": "turbo run typecheck",
		"test": "vitest run --coverage",
		"test:dev": "vitest",
		"test:update": "vitest run --reporter=verbose --update-snapshots",
		"clean": "turbo run clean && rimraf dist dist-site coverage .turbo",
		"prepack": "pnpm run build && pnpm run build:compat",
		"prepare": "husky"
	},
	"dependencies": {
		"@better-scrollbar/core": "workspace:*",
		"@better-scrollbar/react": "workspace:*"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@testing-library/react": "^14.0.0",
		"@types/node": "^20.10.3",
		"@types/react": "^18.2.43",
		"@types/react-dom": "^18.2.17",
		"@vitejs/plugin-react": "^4.2.0",
		"@vitejs/plugin-vue": "^5.2.4",
		"@vitest/coverage-v8": "^1.0.4",
		"@vue/test-utils": "^2.4.6",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-vue": "^10.9.2",
		"husky": "^9.1.7",
		"jsdom": "^20.0.0",
		"less": "^4.2.0",
		"lint-staged": "^17.0.8",
		"prettier": "^3.1.0",
		"resize-observer-polyfill": "^1.5.1",
		"rimraf": "^6.0.0",
		"turbo": "^2.5.4",
		"typescript": "^5.3.2",
		"typescript-eslint": "^8.62.0",
		"vite": "^5.0.8",
		"vitest": "^1.0.4",
		"vue": "^3.5.24",
		"vue-tsc": "^3.3.5"
	},
	"peerDependencies": {
		"react": ">=16.9.0",
		"react-dom": ">=16.9.0"
	},
	"lint-staged": {
		"*.{ts,tsx,vue}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,yml,yaml,css,less}": [
			"prettier --write"
		]
	}
}
