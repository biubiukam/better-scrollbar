{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Node",
		"lib": ["DOM", "DOM.Iterable", "ES2020"],
		"strict": true,
		"allowJs": false,
		"sourceMap": true,
		"declaration": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"stripInternal": true,
		"types": ["node"]
	}
}
