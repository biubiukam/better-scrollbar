{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"emitDeclarationOnly": true,
		"noEmit": false,
		"declaration": true,
		"declarationMap": false,
		"declarationDir": "dist/types",
		"outDir": "dist/types",
		"rootDir": "src",
		"baseUrl": ".",
		"paths": {
			"@better-scrollbar/react": ["packages/react/dist/types/index.d.ts"]
		}
	},
	"include": ["src/index.ts"],
	"exclude": ["node_modules", "dist", "apps/site", "test"]
}
