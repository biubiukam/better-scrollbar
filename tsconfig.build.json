{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"emitDeclarationOnly": true,
		"noEmit": false,
		"declaration": true,
		"declarationMap": false,
		"declarationDir": "dist/types",
		"outDir": "dist/types",
		"rootDir": "build",
		"baseUrl": ".",
		"paths": {
			"@better-scrollbar/react": ["packages/react/dist/types/index.d.ts"]
		}
	},
	"include": ["build/library-entry.ts"],
	"exclude": ["node_modules", "dist", "apps/site"]
}
